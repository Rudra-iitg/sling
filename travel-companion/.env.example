# Environment Variables Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret Key
# IMPORTANT: Change this to a strong, random secret in production
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-long-random-string

# JWT Token Expiration
# Examples: '1h', '7d', '30d'
JWT_EXPIRES_IN=7d

# Database Configuration (for future use when migrating from JSON)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sling_travel
# DB_USER=postgres
# DB_PASSWORD=your_password

# Redis Configuration (for future caching implementation)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Email Configuration (for future email functionality)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@slingtravel.com

# Payment Gateway Configuration (for future implementation)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Map API Keys (for enhanced map features)
# MAPBOX_ACCESS_TOKEN=
# GOOGLE_MAPS_API_KEY=

# AWS S3 Configuration (for file uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=sling-travel-uploads

# Social OAuth Configuration (for future social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# Push Notification Configuration
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@slingtravel.com

# Monitoring & Analytics
# SENTRY_DSN=
# GOOGLE_ANALYTICS_ID=

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=100

# CORS Configuration
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# File Upload Limits
MAX_FILE_SIZE_MB=5

# Security
# BCRYPT_ROUNDS=10
# SESSION_SECRET=your-session-secret-key

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_PAYMENTS=false
ENABLE_EMAIL_VERIFICATION=false

# Application URL
APP_URL=http://localhost:3000

# Admin Configuration
# ADMIN_EMAIL=admin@slingtravel.com
# ADMIN_PASSWORD=change-this-secure-password
